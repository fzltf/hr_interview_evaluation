<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_applicant_form_inherit_interview"
            model="ir.ui.view">
        <field name="name">
            hr.applicant.form.interview.evaluation
        </field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id"
        ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']"
            position="inside">
                <button
                    name="action_view_interview_evaluations"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-comments">
                    <field
                        name="interview_evaluation_count"
                        widget="statinfo"
                        string="Interview Evaluations"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>